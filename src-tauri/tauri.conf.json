{
  "$schema": "https://raw.githubusercontent.com/nicegui-dev/tauri-v2-schema/main/tauri.schema.json",
  "productName": "Burnrate",
  "version": "0.2.1",
  "identifier": "com.burnrate.desktop",
  "build": {
    "frontendDist": "../frontend-neopop/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend-neopop && npm run build",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Burnrate",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "url": "http://localhost:8000"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/burnrate-server",
          "sidecar": true,
          "args": ["--host", "127.0.0.1", "--port", { "validator": "\\d+" }]
        }
      ]
    }
  }
}
