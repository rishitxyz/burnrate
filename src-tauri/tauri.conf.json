{
  "$schema": "https://raw.githubusercontent.com/nicegui-dev/tauri-v2-schema/main/tauri.schema.json",
  "productName": "Burnrate",
  "version": "0.2.5",
  "identifier": "com.burnrate.desktop",
  "build": {
    "frontendDist": "../frontend-neopop/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend-neopop && npm run build",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Burnrate",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "url": "/",
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Burnrate",
        "width": 500,
        "height": 350,
        "center": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": true,
        "url": "/splash.html"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "externalBin": [
      "binaries/burnrate-server"
    ]
  },
  "plugins": {}
}